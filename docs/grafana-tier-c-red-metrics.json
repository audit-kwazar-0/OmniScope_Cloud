{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "uid": "omniscope-tier-c-red",
  "title": "OmniScope — Tier C — RED metrics (services)",
  "tags": ["OmniScope", "tier:C", "RED", "Prometheus", "AMP"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(http_server_request_duration_seconds_count, service)",
        "query": "label_values(http_server_request_duration_seconds_count, service)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "current": { "text": "All", "value": ".+", "selected": true }
      },
      {
        "name": "namespace",
        "label": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(http_server_request_duration_seconds_count{service=~\"$service\"}, namespace)",
        "query": "label_values(http_server_request_duration_seconds_count{service=~\"$service\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "current": { "text": "All", "value": ".+", "selected": true }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "RED (Rate, Errors, Duration)",
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Rate (RPS)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(http_server_request_duration_seconds_count{service=~\"$service\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": { "legend": { "showLegend": true } },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors (% 5xx)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum by (service) (rate(http_server_request_duration_seconds_count{service=~\"$service\", namespace=~\"$namespace\", status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service) (rate(http_server_request_duration_seconds_count{service=~\"$service\", namespace=~\"$namespace\"}[$__rate_interval])), 0.001))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": { "legend": { "showLegend": true } },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Duration p95 (ms)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.95, sum by (le, service) (rate(http_server_request_duration_seconds_bucket{service=~\"$service\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "{{service}}"
        }
      ],
      "options": { "legend": { "showLegend": true } },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top services by error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "topk(15, 100 * (sum by (service) (rate(http_server_request_duration_seconds_count{service=~\"$service\", namespace=~\"$namespace\", status_code=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(http_server_request_duration_seconds_count{service=~\"$service\", namespace=~\"$namespace\"}[5m])), 0.001)))",
          "legendFormat": "{{service}}"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Metric": true }, "renameByName": { "service": "Service", "Value": "Error % (5m)" } } }
      ],
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Error % (5m)", "desc": true }] },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true },
          "links": [
            {
              "title": "Open logs in NOC (Loki)",
              "url": "/d/omniscope-noc-loki-v1?orgId=${__org.id}&from=${__from}&to=${__to}&var-namespace=${namespace:queryparam}&var-app=${__value.raw}&var-pod=.+",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Error % (5m)" }, "properties": [{ "id": "unit", "value": "percent" }] }
        ]
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top services by p95 latency (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "topk(15, 1000 * histogram_quantile(0.95, sum by (le, service) (rate(http_server_request_duration_seconds_bucket{service=~\"$service\", namespace=~\"$namespace\"}[5m]))))",
          "legendFormat": "{{service}}"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Metric": true }, "renameByName": { "service": "Service", "Value": "p95 (ms)" } } }
      ],
      "options": { "showHeader": true, "sortBy": [{ "displayName": "p95 (ms)", "desc": true }] },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true },
          "links": [
            {
              "title": "Open logs in NOC (Loki)",
              "url": "/d/omniscope-noc-loki-v1?orgId=${__org.id}&from=${__from}&to=${__to}&var-namespace=${namespace:queryparam}&var-app=${__value.raw}&var-pod=.+",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95 (ms)" }, "properties": [{ "id": "unit", "value": "ms" }] }
        ]
      }
    },
    {
      "id": 7,
      "type": "text",
      "title": "Notes",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 17 },
      "options": {
        "mode": "markdown",
        "content": "This dashboard expects RED metrics in Prometheus format: `http_server_request_duration_seconds_count`, `_bucket` and label set including `service`, `namespace`, and `status_code`. If your metrics use different names (for example `http_requests_total` or `http_request_duration_seconds_*`), update queries accordingly."
      }
    }
  ]
}
