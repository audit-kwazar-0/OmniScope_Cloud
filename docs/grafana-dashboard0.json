{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "2.9.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "uid": "omniscope-noc-loki-v1",
  "title": "OmniScope NOC (Loki)",
  "schemaVersion": 39,
  "version": 1,
  "style": "dark",
  "editable": true,
  "timezone": "browser",
  "graphTooltip": 1,
  "liveNow": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "namespace",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({job=\"kubernetes-pods\"}, namespace)",
        "query": {
          "query": "label_values({job=\"kubernetes-pods\"}, namespace)",
          "refId": "NamespaceVar"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "current": { "text": "omniscope", "value": "omniscope", "selected": true }
      },
      {
        "name": "app",
        "label": "app",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({namespace=~\"$namespace\", app=~\".+\"}, app)",
        "query": {
          "query": "label_values({namespace=~\"$namespace\", app=~\".+\"}, app)",
          "refId": "AppVar"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "current": { "text": "All", "value": ".+", "selected": true }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "System Health & Error Rates",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"}[$__interval]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ERROR / CRITICAL Logs",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"} |~ \"(?i)error|critical\" [$__interval]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Success Logs (%)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"}[$__interval])) - sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"} |~ \"(?i)error|critical\" [$__interval]))) / (sum(count_over_time({namespace=~\"$namespace\", app=~\"$app\"}[$__interval])) + 1)",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Log Rate & Volatility",
      "id": 101,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log Rate by Container",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container) (count_over_time({namespace=~\"$namespace\", app=~\"$app\"}[$__interval]))",
          "queryType": "range",
          "legendFormat": "{{container}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Error Investigation",
      "id": 102,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Error Logs by App",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (app) (count_over_time({namespace=~\"$namespace\", app=~\"$app\"} |~ \"(?i)error|fail|exception|critical\" [$__interval]))",
          "queryType": "range",
          "legendFormat": "{{app}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": { "displayMode": "hidden", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Live Error Stream",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=~\"$namespace\", app=~\"$app\"} |~ \"(?i)error|fail|exception\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
