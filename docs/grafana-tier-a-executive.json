{
  "__inputs": [
    { "name": "DS_AM", "label": "Azure Monitor", "type": "datasource", "pluginId": "grafana-azure-monitor-datasource", "pluginName": "Azure Monitor" }
  ],
  "uid": "omniscope-tier-a",
  "title": "OmniScope — Tier A — Executive health",
  "tags": ["OmniScope", "tier:A", "Azure", "AKS"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "AKS — overview (Log Analytics / Container Insights)",
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Nodes (inventory)",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
          "azureLogAnalytics": {
            "query": "KubeNodeInventory\n| where TimeGenerated > ago(15m)\n| where ClusterName =~ \"__AKS_NAME__\"\n| summarize Nodes = count()",
            "resources": ["__LOG_ANALYTICS_ARM_ID__"],
            "resultFormat": "table"
          }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pods (inventory)",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
          "azureLogAnalytics": {
            "query": "KubePodInventory\n| where TimeGenerated > ago(15m)\n| where ClusterName =~ \"__AKS_NAME__\"\n| summarize Pods = count()",
            "resources": ["__LOG_ANALYTICS_ARM_ID__"],
            "resultFormat": "table"
          }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Warning events (24h)",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
          "azureLogAnalytics": {
            "query": "KubeEvents\n| where TimeGenerated > ago(24h)\n| where ClusterName =~ \"__AKS_NAME__\"\n| where KubeEventType =~ \"Warning\"\n| summarize Warnings = count()",
            "resources": ["__LOG_ANALYTICS_ARM_ID__"],
            "resultFormat": "table"
          }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Namespaces (inventory)",
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AM}" },
          "azureLogAnalytics": {
            "query": "KubePodInventory\n| where TimeGenerated > ago(15m)\n| where ClusterName =~ \"__AKS_NAME__\"\n| summarize NS = dcount(Namespace)",
            "resources": ["__LOG_ANALYTICS_ARM_ID__"],
            "resultFormat": "table"
          }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "colorMode": "value",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ]
}
