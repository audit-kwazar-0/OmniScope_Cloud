{
  "__inputs": [
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki", "pluginName": "Loki" }
  ],
  "uid": "omniscope-tier-e",
  "title": "OmniScope — Tier E — Logs & evidence",
  "tags": ["OmniScope", "tier:E", "Loki"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Fast error stream",
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "text",
      "title": "NOC link",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 1 },
      "options": {
        "mode": "markdown",
        "content": "Full incident table and parsing live in **[OmniScope NOC (Loki)](/d/omniscope-noc-loki-v1)**. Here is a compact **log panel** for drill-down.\n"
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Error / critical / fail / exception",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=~\".+\", app=~\".+\"} |~ `(?i)error|critical|fail|exception`",
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
